<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_mq_bundle" model="ir.ui.view">
        <field name="name">product.template.form.mq.bundle</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="mq_is_bundle_weight"/>
                <field name="mq_bundle_multiplier" invisible="not mq_is_bundle_weight"/>
            </xpath>
        </field>
    </record>
</odoo>
