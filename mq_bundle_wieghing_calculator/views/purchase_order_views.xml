<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_mq_bundle" model="ir.ui.view">
        <field name="name">purchase.order.form.mq.bundle</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- Inject fields into the order lines table -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_qty']" position="before">
                <field name="mq_bundle_qty" />
                <field name="mq_quantity" />
            </xpath>
            
            <xpath expr="//field[@name='order_line']//list//field[@name='product_qty']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>

            <!-- Add totals to the bottom of the form -->
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="after">
                <group class="oe_subtotal_footer oe_right">
                    <field name="mq_total_weight" />
                    <field name="mq_total_bundle_qty" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
