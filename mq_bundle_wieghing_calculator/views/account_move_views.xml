<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_mq_bundle" model="ir.ui.view">
        <field name="name">account.move.form.mq.bundle</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='quantity']" position="before">
                <field name="mq_bundle_qty" />
                <field name="mq_quantity" />
                <field name="mq_qty_delivered" column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
                <field name="mq_qty_received" column_invisible="parent.move_type not in ('in_invoice', 'in_refund')"/>
            </xpath>
            
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='quantity']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_uom_id']" position="attributes">
                <attribute name="string">Unit</attribute>
            </xpath>

            <!-- Add totals to the bottom of the invoice form -->
            <xpath expr="//field[@name='tax_totals']" position="after">
                <field name="mq_total_weight" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')"/>
                <field name="mq_total_bundle_qty" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
