<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_mq_transportation_details" model="ir.ui.view">
        <field name="name">sale.order.form.mq.transportation.details</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[1]" position="inside">
                <group string="Transportation Details" name="transportation_details">
                    <field name="driver_name_id"/>
                    <field name="driver_phone_id"/>
                    <field name="car_plate_id"/>
                    <field name="border_crossing_id"/>
                    <field name="scale_no_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
