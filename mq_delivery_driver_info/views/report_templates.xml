                <div t-if="o.car_plate_id"><strong>Car Plate No.:</strong> <span t-field="o.car_plate_id.name"/></div>
                <div t-if="o.border_crossing_id"><strong>Border Crossing:</strong> <span t-field="o.border_crossing_id.name"/></div>
                <div t-if="o.scale_no_id"><strong>Scale No.:</strong> <span t-field="o.scale_no_id.name"/></div>
            </div>
        </xpath>
    </template>

    <!-- Delivery Slip Report Extension -->
    <template id="report_delivery_document_driver_info" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@id='informations']" position="before">
            <div id="mq_driver_info" class="mb-4">
                <div t-if="o.driver_name_id"><strong>Driver Name:</strong> <span t-field="o.driver_name_id.name"/></div>
