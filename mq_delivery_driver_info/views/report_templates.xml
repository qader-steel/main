<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Force Reports to follow User's Session Language -->
    <template id="report_saleorder_user_lang" inherit_id="sale.report_saleorder_raw">
        <xpath expr="//t[@t-call='sale.report_saleorder_document']" position="attributes">
            <attribute name="t-lang">env.user.lang</attribute>
        </xpath>
    </template>

    <template id="report_invoice_user_lang" inherit_id="account.report_invoice">
        <xpath expr="//t[@t-foreach='docs']//t[@t-set='lang']" position="attributes">
            <attribute name="t-value">env.user.lang</attribute>
        </xpath>
    </template>

    <template id="report_deliveryslip_user_lang" inherit_id="stock.report_deliveryslip">
        <xpath expr="//t[@t-foreach='docs']//t[@t-call='stock.report_delivery_document']" position="attributes">
            <attribute name="t-lang">env.user.lang</attribute>
        </xpath>
    </template>

    <!-- Sale Order Report Extension -->
    <template id="report_saleorder_document_driver_info" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@id='informations']" position="before">
            <t t-set="doc" t-value="doc.with_context(lang=env.user.lang)"/>
            <div id="mq_driver_info" class="row mb-2" style="margin: 0; padding: 10px 16px; background-color: #eef2f7; border-radius: 8px;">
                <div t-if="doc.driver_name_id" class="col text-center">
                    <div style="font-weight: 600; font-size: 0.8em; color: #555; text-transform: uppercase; letter-spacing: 0.03em;">
                        <t t-if="env.user.lang and env.user.lang[:2] == 'ar'">اسم السائق</t>
                        <t t-else="">Driver Name</t>
                    </div>
                    <div style="font-size: 1.05em; font-weight: 700;" t-field="doc.driver_name_id.name"/>
                </div>
                <div t-if="doc.driver_phone_id" class="col text-center">
                    <div style="font-weight: 600; font-size: 0.8em; color: #555; text-transform: uppercase; letter-spacing: 0.03em;">
                        <t t-if="env.user.lang and env.user.lang[:2] == 'ar'">رقم هاتف السائق</t>
                        <t t-else="">Driver Phone No.</t>
                    </div>
                    <div style="font-size: 1.05em; font-weight: 700;" t-field="doc.driver_phone_id.name"/>
                </div>
                <div t-if="doc.car_plate_id" class="col text-center">
                    <div style="font-weight: 600; font-size: 0.8em; color: #555; text-transform: uppercase; letter-spacing: 0.03em;">
                        <t t-if="env.user.lang and env.user.lang[:2] == 'ar'">رقم لوحة السيارة</t>
                        <t t-else="">Car Plate No.</t>
                    </div>
                    <div style="font-size: 1.05em; font-weight: 700;" t-field="doc.car_plate_id.name"/>
                </div>
                <div t-if="doc.border_crossing_id" class="col text-center">
                    <div style="font-weight: 600; font-size: 0.8em; color: #555; text-transform: uppercase; letter-spacing: 0.03em;">
                        <t t-if="env.user.lang and env.user.lang[:2] == 'ar'">معبر الحدود</t>
                        <t t-else="">Border Crossing</t>
                    </div>
                    <div style="font-size: 1.05em; font-weight: 700;" t-field="doc.border_crossing_id.name"/>
                </div>
                <div t-if="doc.scale_no_id" class="col text-center">
                    <div style="font-weight: 600; font-size: 0.8em; color: #555; text-transform: uppercase; letter-spacing: 0.03em;">
                        <t t-if="env.user.lang and env.user.lang[:2] == 'ar'">رقم المقياس</t>
                        <t t-else="">Scale No.</t>
                    </div>
                    <div style="font-size: 1.05em; font-weight: 700;" t-field="doc.scale_no_id.name"/>
                </div>
            </div>
        </xpath>
    </template>

