<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_mq_transportation_details" model="ir.ui.view">
        <field name="name">purchase.order.form.mq.transportation.details</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Transportation Details" name="transportation_details">
                    <group>
                        <field name="driver_name_id"/>
                        <field name="driver_phone_id"/>
                        <field name="car_plate_id"/>
                    </group>
                    <group>
                        <field name="border_crossing_id"/>
                        <field name="scale_no_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
