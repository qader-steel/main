<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_mq_transportation_details" model="ir.ui.view">
        <field name="name">account.move.form.mq.transportation.details</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Transportation Details" name="transportation_details" invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group>
                        <field name="driver_name_id"/>
                        <field name="driver_phone_id"/>
                        <field name="car_plate_id"/>
                    </group>
                    <group>
                        <field name="border_crossing_id"/>
                        <field name="scale_no_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
